    (sheet (number "1") (name "/") (tstamps "/")
      (title_block
        (title "HeatValve-6 Rev2: 6x dumb H-bridge + shared unipolar shunt (current+tacho+force-limit)")
        (comment (number "1") (value "Pinouts verified: DRV8837DSGR C39159; WROOM-1 C2913202; LM324 C351427; LM339 C504552; 74HC74 C27597; AP2112K C51118"))
        (comment (number "2") (value "Power: VM -> +5V (=VM if VM<=5.5V, else buck) -> AP2112K -> +3V3. AP2112K VIN max 6V."))
        (comment (number "3") (value "Force-limit latch: trip clocks D=0 into Q -> DRIVE_PERMIT low -> all nSLEEP low. MCU pulses nPRE low to re-arm."))
        (comment (number "4") (value "U12 (4051) and BEMF path are DNP/optional — power wired, signal path omitted (separate sub-sheet)."))) ))
